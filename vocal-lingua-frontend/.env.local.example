# ─────────────────────────────────────────────────────────────────────
# Gabsther Frontend — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────

# Django backend base URL — localhost for dev, your Render URL for prod
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# App URL (for PWA manifest & OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

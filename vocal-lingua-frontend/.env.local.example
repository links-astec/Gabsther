# ─────────────────────────────────────────────────────────────────────
# VocalLingua Frontend — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────

# Django backend base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# OpenAI key (optional — only needed if calling OpenAI directly from
# the browser; otherwise the Django proxy handles it)
NEXT_PUBLIC_OPENAI_KEY=

# App URL (for PWA manifest & OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Gabsther Backend — Environment Variables (Production)
# ─────────────────────────────────────────────────────────────
# Copy this to .env and fill in your production values

# Django — Security
SECRET_KEY=k=64o$ezd1^0hu56i2-z=414*3dyx@ki)5yqrte!mtwua3)1*6
DEBUG=False
ALLOWED_HOSTS=gabsther-api.onrender.com,localhost,127.0.0.1

# Database — PostgreSQL in production (Render provides this automatically)
# For local SQLite dev: sqlite:///db.sqlite3
# For PostgreSQL: postgresql://user:password@localhost:5432/gabsther
DATABASE_URL=postgresql://gabsther_db_user:your_secure_password@localhost:5432/gabsther

# CORS — Frontend domain (update when you deploy to Vercel)
CORS_ALLOWED_ORIGINS=https://gabsther-sand.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# JWT Token lifetimes (in minutes / days)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Groq AI — Language model for voice chat
